{
  "name": "kordoc",
  "version": "0.1.0",
  "description": "Parse Korean documents (HWP, HWPX, PDF) to Markdown",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "bin": {
    "kordoc": "./dist/cli.mjs"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "hwp",
    "hwpx",
    "hancom",
    "hangul",
    "korean",
    "document",
    "parser",
    "pdf",
    "markdown",
    "converter"
  ],
  "author": "chrisryugj",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/chrisryugj/kordoc.git"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@xmldom/xmldom": "^0.9.8",
    "cfb": "^1.2.2",
    "commander": "^13.0.0",
    "jszip": "^3.10.1",
    "pdfjs-dist": "^5.5.207"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "tsup": "^8.4.0",
    "typescript": "^5.9.0"
  }
}
